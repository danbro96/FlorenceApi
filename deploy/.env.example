# Copy to deploy/.env on the deploy host. compose.yaml reads these.

# REQUIRED: API key clients must present in X-API-Key (or ?api_key=).
# Generate with: openssl rand -hex 32
FLORENCE_API_KEY=REPLACE_ME_64HEX
FLORENCE_API_KEY_NAME=prod

# Image tag to pull. "latest" = main branch; pin to sha-XXXXXXX for reproducible deploys.
IMAGE_TAG=latest

# Public port the .NET service listens on. Worker is internal-only.
HOST_PORT=40380

# Per-key rate limit (requests per minute, token bucket).
RATE_LIMIT=60

# Inference timeout in seconds for the .NET-to-worker call.
REQUEST_TIMEOUT=60

# Max upload size in bytes (also enforced server-side at the worker).
MAX_IMAGE_BYTES=8388608

# CORS: leave blank to disable, or set to your frontend origin.
ALLOWED_ORIGIN=

# Hugging Face model selection. Pin MODEL_REVISION to a commit SHA for reproducibility
# once you've validated a working snapshot.
MODEL_ID=microsoft/Florence-2-base-ft
MODEL_REVISION=main

# OpenVINO device override. Leave blank to auto-pick first GPU; set to GPU.0/GPU.1/CPU
# to force. On a host with only an Arc dGPU and no iGPU, "GPU" is the right value.
DEVICE=

# Render group GID on the deploy host. Find with: getent group render | cut -d: -f3
# Default 993 matches Debian/Ubuntu.
RENDER_GID=993

# OpenTelemetry. Leave blank to disable; otherwise point at the OpenObserve endpoint.
# When OTEL_EXPORTER_OTLP_ENDPOINT is empty the .NET service skips OTel setup entirely.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:5080/api/default
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OpenObserve OSS requires authenticated ingestion. Generate the value via:
#   echo -n "<openobserve-admin-email>:<openobserve-admin-password>" | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64>
# Metric export cadence in ms. 300000 = 5 min — reduces ingest cost vs OTel default 60s.
OTEL_METRIC_EXPORT_INTERVAL=300000
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod
